{
  "specDir": "sdd/specs",
  "scanDirs": ["tooling"],
  "testFileRegex": ["\\.test\\.mjs$"],
  "ownershipCategories": ["Modules", "Symbols", "Artifacts"],
  "ignoreDirs": [
    "node_modules", ".git", "go-gate", "docs", "ears-preset",
    ".next", "coverage", "dist", "build", "out", "target", "vendor",
    "__pycache__", ".venv", "venv", ".idea", ".gradle", "bin", "obj",
    "Pods", ".dart_tool"
  ],
  "specIdPrefixes": ["SPEC", "INFRA", "TEST"],
  "maxKeysPerCategoryPerSpec": 7,
  "maxFRsPerSpec": 10,
  "requireAccounting": true,
  "smokeManifest": "sdd/smoke-manifest.json",
  "strictSpecs": ["SPEC-002", "SPEC-003", "SPEC-005", "SPEC-006", "SPEC-007", "SPEC-008"],
  "specSyncUnownedPolicy": "warn",
  "entityRegistry": {
    "key-pipeline": "소유권 키 파싱·정규화·config 어댑터의 SSOT 모듈(SPEC-001)",
    "spec-quality-gates": "spec 품질 게이트군 — coverage·dedup·cohesion·completeness·consistency·adequacy(SPEC-002)",
    "spec-sync": "spec-first 강제 게이트군 — spec-sync·converge·orphan(SPEC-003)",
    "harness-install": "훅·게이트 설치 하네스와 러너(SPEC-004)",
    "adoption-lifecycle": "채택 수명주기 스킬 3종(SPEC-005)",
    "runtime-parity": "비-Node 런타임 복제 충실도(SPEC-006)",
    "verification-accounting": "FR 검증 회계 — strictSpecs·requireAccounting·smokeManifest(SPEC-007)",
    "spec-lifecycle": "스펙 수명주기 상태·리뷰 기록 문법(SPEC-008)"
  },
  "specSyncExemptGlobs": [
    "*.md", "*.html", ".gitignore", "docs/**", "prompts/**", "templates/**",
    "sdd.config.json", "sdd/smoke-manifest.json",
    "tooling/*.md", "tooling/*.yml", "tooling/vitest.config.ts"
  ],
  "commands": {
    "test": "node --test tooling/__tests__/*.mjs"
  }
}
