#!/bin/sh
# git pre-commit — 방법론 게이트 hard 차단.
# sdd-init가 scripts/sdd-pre-commit.sh로 설치 + .git/hooks/pre-commit(및 pre-merge-commit)이 이를 호출.
#
# 경로 필터 없음(감사 P3): 과거 src/|lib/|app/|tests/ 하드코딩 필터는 Go(cmd/·pkg/)·Python 패키지
# 등 비-JS 레이아웃에서 게이트를 한 번도 발동시키지 않았다 — config scanDirs(언어 무관 어댑터)와
# 어긋난 강제 지점. 게이트는 레포 상태 전역 스캔이라(스테이징 내용 비의존) 매 커밋 실행이 옳고 빠르다.
set -e
DIR=$(git rev-parse --show-toplevel) || { echo "sdd pre-commit: git 저장소 아님" >&2; exit 1; }
cd "$DIR"
if [ ! -f scripts/check-fr-coverage.mjs ] || [ ! -f scripts/check-ownership.mjs ]; then
  echo "sdd pre-commit: 게이트가 scripts/에 없음 — sdd-init 재실행 필요" >&2
  exit 1
fi
node scripts/check-fr-coverage.mjs   # PREFIX 화이트리스트·사유·번호 무결성·조용한누락(exit 1)
node scripts/check-ownership.mjs     # dedup·정규화·형식·관계 실재(exit 1)
